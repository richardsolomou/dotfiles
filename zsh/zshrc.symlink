# --- SSH ---

# 1Password SSH agent
if [ -S "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock" ]; then
  export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
fi

# --- Secrets (never committed) ---
if [ -f "$HOME/.secrets" ]; then
  . "$HOME/.secrets"
fi

# --- Build environment ---
export OPENSSL_ROOT_DIR="/opt/homebrew/opt/openssl@3"
export OPENSSL_LIB_DIR="/opt/homebrew/opt/openssl@3/lib"
export OPENSSL_INCLUDE_DIR="/opt/homebrew/opt/openssl@3/include"
export PKG_CONFIG_PATH="/opt/homebrew/opt/openssl@3/lib/pkgconfig"
export CPPFLAGS="-I/opt/homebrew/opt/openssl/include"
export LDFLAGS="-L/opt/homebrew/opt/openssl/lib"

# --- Language/tool managers ---

# mise (replaces pyenv, rbenv, nvm)
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# direnv
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

# --- PATH additions ---

# Go
if [ -d "$HOME/go/bin" ]; then
  export PATH="$HOME/go/bin:$PATH"
fi

# Dotfiles bin
export PATH="$HOME/.dotfiles/bin:$PATH"

# Local bin (claude code, pipx, etc.)
if [ -d "$HOME/.local/bin" ]; then
  export PATH="$HOME/.local/bin:$PATH"
fi

# PostHog infra scripts
if [ -d "$HOME/dev/posthog/posthog/infra-scripts/mcp" ]; then
  export PATH="$HOME/dev/posthog/posthog/infra-scripts/mcp:$PATH"
fi

export POSTHOG_WORKTREE_BASE="$HOME/dev/worktrees"

# --- Shell utilities ---

listening() {
  if [ $# -eq 0 ]; then
    sudo lsof -iTCP -sTCP:LISTEN -n -P
  elif [ $# -eq 1 ]; then
    sudo lsof -iTCP -sTCP:LISTEN -n -P | grep -i --color "$1"
  else
    echo "Usage: listening [pattern]"
  fi
}

killpid() {
  if [ $# -eq 1 ]; then
    kill -9 "$1"
  else
    kill
  fi
}

# --- Shell history ---
HISTSIZE=100000
SAVEHIST=100000
HISTFILE="$HOME/.zsh_history"
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS

# --- Aliases and completions ---
autoload -Uz compinit && compinit
source "$HOME/.dotfiles/zsh/aliases.zsh"
source "$HOME/.dotfiles/zsh/claude-completion.zsh"
source "$HOME/.dotfiles/zsh/gt-completion.zsh"

# tree-me auto-cd support
if command -v tree-me >/dev/null 2>&1; then
  source <(tree-me shellenv)
fi

# --- Starship prompt ---
eval "$(starship init zsh)"
