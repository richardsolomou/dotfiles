# Example .env for bin/sync-skills. Copy to .env (gitignored) and fill in.

# Required. PostHog personal API key with llm_skill:read and llm_skill:write scopes.
# Create at https://us.posthog.com/settings/user-api-keys
POSTHOG_PERSONAL_API_KEY=

# Optional. Defaults to 2 (the PostHog App + Website project where richard-* skills live).
# POSTHOG_PROJECT_ID=2

# Optional. Defaults to https://us.posthog.com. Override for EU cloud or self-hosted.
# POSTHOG_HOST=https://us.posthog.com
